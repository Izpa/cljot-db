# ============ cljot-crud new-server config ============
# Copy to .env and fill in. `setup.sh` reads this file. Do NOT commit .env.

# ---- Postgres (internal to the compose network) ----
DB_NAME=default
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_db_password

# ---- S3 / SeaweedFS (the bot creates the bucket on first start) ----
# These become the SeaweedFS root credentials AND the bot's S3 credentials.
# Keep them free of quotes and backslashes.
MINIO_USER=CHANGE_ME_access_key
MINIO_PASSWORD=CHANGE_ME_secret_key
MINIO_BUCKET=cljot-db-bucket

# ---- Telegram ----
# Generate a fresh token in @BotFather (the old one lived in CapRover env and is lost).
TELEGRAM_BOT_TOKEN=123456:CHANGE_ME
# Comma-separated Telegram user IDs with admin rights (upload/rename/delete).
# The 3 restored users are: 108673844, 112789249, 5804239176 — pick which are admins.
TELEGRAM_ADMIN_IDS=108673844
# Invite code: anonymous users send `/start <INVITE>` to register.
INVITE=CHANGE_ME_invite_code

# ---- Optional ----
PAGE_SIZE=3
